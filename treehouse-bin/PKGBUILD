# Maintainer: Niko Lehtovirta <niko@lehtovirta.dev>

pkgname=treehouse-bin
pkgver=2.0.1
pkgrel=1
pkgdesc="Manage worktrees without managing worktrees"
arch=('x86_64')
options=('!debug')
url="https://github.com/kunchenguid/treehouse"
license=('MIT')
depends=('git' 'glibc')
provides=('treehouse')
conflicts=('treehouse')

source=(
  "https://github.com/kunchenguid/treehouse/releases/download/v${pkgver}/treehouse-v${pkgver}-linux-amd64.tar.gz"
  "LICENSE::https://raw.githubusercontent.com/kunchenguid/treehouse/v${pkgver}/LICENSE"
)
sha256sums=('1d5a32751ab921670103fd201ddb2b91b47338cb13976f45642b827cf8976af2'
            '1b962d20f826f6a758c737f8aa4e8e76dc719b8aa78fcfacdfb46681bb36c2f4')

package() {
  install -Dm755 "$srcdir/treehouse" "$pkgdir/usr/bin/treehouse"
  install -Dm644 "$srcdir/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
