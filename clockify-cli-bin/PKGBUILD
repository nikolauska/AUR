pkgname=clockify-cli-bin
pkgver=0.64.1
pkgrel=1
pkgdesc="CLI for interacting with Clockify's API"
arch=('x86_64' 'aarch64')
options=('!debug')
url="https://github.com/lucassabreu/clockify-cli"
license=('Apache-2.0')
provides=('clockify-cli')
conflicts=('clockify-cli')

source_x86_64=("clockify-cli-${pkgver}-x86_64.tar.gz::https://github.com/lucassabreu/clockify-cli/releases/download/v${pkgver}/clockify-cli_Linux_x86_64.tar.gz")
source_aarch64=("clockify-cli-${pkgver}-aarch64.tar.gz::https://github.com/lucassabreu/clockify-cli/releases/download/v${pkgver}/clockify-cli_Linux_arm64.tar.gz")
sha256sums_x86_64=('19360ed5a85a6825ada183a69a4fa95ba09b6af68145560357abded3abec74a8')
sha256sums_aarch64=('8b0ee6d86519340a9348cbf3f0d267072f7d33569933655e3436e98561e96014')

package() {
  install -Dm755 "$srcdir/clockify-cli" "$pkgdir/usr/bin/clockify-cli"
  install -Dm644 "$srcdir/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
