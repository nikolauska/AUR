# Maintainer: Niko Lehtovirta <niko@lehtovirta.dev>

pkgname=sentry-cli-bin
pkgver=0.38.0
pkgrel=1
pkgdesc="Command-line interface for Sentry"
arch=('x86_64' 'aarch64')
options=('!debug' '!strip')
url="https://github.com/getsentry/cli"
license=('FSL-1.1-ALv2')
depends=('glibc' 'gcc-libs')
provides=('sentry')
conflicts=('sentry')

source=("LICENSE.md::https://raw.githubusercontent.com/getsentry/cli/${pkgver}/LICENSE.md")
source_x86_64=("sentry-${pkgver}-x86_64.gz::https://github.com/getsentry/cli/releases/download/${pkgver}/sentry-linux-x64.gz")
source_aarch64=("sentry-${pkgver}-aarch64.gz::https://github.com/getsentry/cli/releases/download/${pkgver}/sentry-linux-arm64.gz")
sha256sums=('c51f382a888f8f59f54a72af01e2d72032f2ba8f31d8194f8bf489123438195a')
sha256sums_x86_64=('41b74257528608c430ce4a637a65725018749c7086845e72890cbe88968154c7')
sha256sums_aarch64=('e3655f847c632d3b74034c8cfbfc5a878a3c80a500dca4a4547c1f20a806978d')

package() {
  install -Dm755 "$srcdir/sentry-${pkgver}-${CARCH}" "$pkgdir/usr/bin/sentry"
  install -Dm644 "$srcdir/LICENSE.md" "$pkgdir/usr/share/licenses/$pkgname/LICENSE.md"
}
