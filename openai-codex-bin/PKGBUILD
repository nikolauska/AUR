pkgname=openai-codex-bin
pkgver=0.129.0
pkgrel=1
pkgdesc="Lightweight coding agent that runs in your terminal (binary release)"
arch=('x86_64')
options=('!debug')
url="https://github.com/openai/codex"
license=('Apache-2.0')
provides=('openai-codex')
conflicts=('openai-codex')
optdepends=(
  'git: for working with git repositories'
  'ripgrep: accelerated large-repo search'
)

source=(
  "codex-${pkgver}-${CARCH}.tar.gz::https://github.com/openai/codex/releases/download/rust-v${pkgver}/codex-${CARCH}-unknown-linux-musl.tar.gz"
)
sha256sums=('4a4a28d22dd1f874e2c7b23d9ba13db02bf7ad4ee9a70b9c4eaab618708d0582')

package() {
  cd "$srcdir"

  install -Dm755 "codex-${CARCH}-unknown-linux-musl" "$pkgdir/usr/bin/codex"
}
