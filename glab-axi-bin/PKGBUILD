pkgname=glab-axi-bin
pkgver=0.1.0
pkgrel=1
pkgdesc="Agent-oriented GitLab CLI with compact TOON output"
arch=('x86_64' 'aarch64')
options=('!debug')
url="https://github.com/nikolauska/glab-axi"
license=('MIT')
depends=('glab')
provides=('glab-axi')
conflicts=('glab-axi')

source=("LICENSE::https://raw.githubusercontent.com/nikolauska/glab-axi/v${pkgver}/LICENSE")
source_x86_64=("glab-axi-${pkgver}-x86_64::https://github.com/nikolauska/glab-axi/releases/download/v${pkgver}/glab-axi-linux-amd64")
source_aarch64=("glab-axi-${pkgver}-aarch64::https://github.com/nikolauska/glab-axi/releases/download/v${pkgver}/glab-axi-linux-arm64")
sha256sums=('c770b9f4a2da970e9bb22311960dbf4de363ab828fe13d2591a5dc0a8e09b983')
sha256sums_x86_64=('a2f75c8f5bc99fbde62f846d5395dfe5f4928bcb143b119129915b8d75e6dcdc')
sha256sums_aarch64=('3202cd166889920c3757e11dbf243a74b042a132f8916b3cc0ad69878f0ca5c9')

package() {
  install -Dm755 "$srcdir/glab-axi-${pkgver}-${CARCH}" "$pkgdir/usr/bin/glab-axi"
  install -Dm644 "$srcdir/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
