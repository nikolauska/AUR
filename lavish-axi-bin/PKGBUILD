# Maintainer: Niko Lehtovirta <niko@lehtovirta.dev>

pkgname=lavish-axi-bin
_pkgname=lavish-axi
pkgver=0.1.37
pkgrel=1
pkgdesc="HTML artifact editor for agent collaboration"
arch=('any')
url="https://github.com/kunchenguid/lavish-axi"
license=('MIT')
depends=('nodejs>=22')
makedepends=('npm')
optdepends=('xdg-utils: open the editor in a browser')
provides=('lavish-axi')
conflicts=('lavish-axi')

source=("https://registry.npmjs.org/${_pkgname}/-/${_pkgname}-${pkgver}.tgz")
noextract=("${_pkgname}-${pkgver}.tgz")
sha512sums=('a16c3cb3474757dc7f631579eea457a03a351f9ae878c5d27d42d63c558464409dc75882781f5d2bcea76e87445a28fb1bcf22fccf4366d791c1c6140923a41b')

package() {
  npm install -s -g \
    --cache "${srcdir}/npm-cache" \
    --prefix "${pkgdir}/usr" \
    "${srcdir}/${_pkgname}-${pkgver}.tgz"

  install -Dm644 \
    "${pkgdir}/usr/lib/node_modules/${_pkgname}/LICENSE" \
    "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
