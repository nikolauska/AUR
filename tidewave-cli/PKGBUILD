pkgname=tidewave-cli
pkgver=0.4.3
pkgrel=1
pkgdesc="Tidewave CLI"
arch=('x86_64')
options=('!debug')
url="https://github.com/tidewave-ai/tidewave_app"
license=('Apache-2.0')
depends=('glibc' 'libgcc_s.so')
provides=('tidewave-cli')

source=(
  "tidewave-cli-${CARCH}-${pkgver}-${pkgrel}-unknown-linux-gnu::https://github.com/tidewave-ai/tidewave_app/releases/download/v${pkgver}/tidewave-cli-${CARCH}-unknown-linux-gnu"
)
sha256sums=('09178bf2df9f21d3a335707e858341654b6e3b960049fe2075a734ffcd14424e')

package() {
  cd "$srcdir"

  install -Dm755 "tidewave-cli-${CARCH}-${pkgver}-${pkgrel}-unknown-linux-gnu" "$pkgdir/usr/bin/tidewave"
}
