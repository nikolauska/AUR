# Maintainer: Niko Lehtovirta <niko@lehtovirta.dev>

pkgname=sentry-axi-bin
_pkgname=sentry-axi
pkgver=0.2.1
pkgrel=1
pkgdesc="AXI wrapper for the Sentry MCP server"
arch=('x86_64' 'aarch64')
options=('!debug' '!strip')
url="https://www.npmjs.com/package/@nikolauska/sentry-axi"
license=('MIT')
depends=('nodejs>=24')
makedepends=('npm')
provides=('sentry-axi')
conflicts=('sentry-axi')

source=("${_pkgname}-${pkgver}.tgz::https://registry.npmjs.org/@nikolauska/${_pkgname}/-/${_pkgname}-${pkgver}.tgz")
noextract=("${_pkgname}-${pkgver}.tgz")
sha512sums=('0935d696244d502fa0f3e950ffbc2c24c7f759db8eed8bceaa32c6cfcec6f2dd4bbbe743225f4b68b6e0038b7d3da96dd5584e4b8129bf3ece247950729fa00d')

package() {
  npm install -s -g \
    --cache "${srcdir}/npm-cache" \
    --prefix "${pkgdir}/usr" \
    "${srcdir}/${_pkgname}-${pkgver}.tgz"

  install -Dm644 \
    "${pkgdir}/usr/lib/node_modules/@nikolauska/${_pkgname}/LICENSE" \
    "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
