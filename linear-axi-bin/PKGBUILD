# Maintainer: Niko Lehtovirta <niko@lehtovirta.dev>

pkgname=linear-axi-bin
_pkgname=linear-axi
pkgver=0.3.1
pkgrel=1
pkgdesc="AXI wrapper for the Linear MCP server"
arch=('x86_64' 'aarch64')
options=('!debug' '!strip')
url="https://www.npmjs.com/package/@nikolauska/linear-axi"
license=('MIT')
depends=('nodejs>=20')
makedepends=('npm')
provides=('linear-axi')
conflicts=('linear-axi')

source=("${_pkgname}-${pkgver}.tgz::https://registry.npmjs.org/@nikolauska/${_pkgname}/-/${_pkgname}-${pkgver}.tgz")
noextract=("${_pkgname}-${pkgver}.tgz")
sha512sums=('f9c8f72c2cc9dbd13b96929c81d3e5611ec172b171645efdf2edd415ee8e81a4501fcebc011c2320991a506a37b4cd130e324d2e779cc06edc4c1e12211dfee7')

package() {
  npm install -s -g \
    --cache "${srcdir}/npm-cache" \
    --prefix "${pkgdir}/usr" \
    "${srcdir}/${_pkgname}-${pkgver}.tgz"

  install -Dm644 \
    "${pkgdir}/usr/lib/node_modules/@nikolauska/${_pkgname}/LICENSE" \
    "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
