# Maintainer: Niko Lehtovirta <niko@lehtovirta.dev>

pkgname=stripe-mock-bin
pkgver=0.200.0
pkgrel=1
pkgdesc="Mock HTTP server that responds like the Stripe API"
arch=('x86_64')
options=('!debug')
url="https://github.com/stripe/stripe-mock"
license=('MIT')
provides=('stripe-mock')
conflicts=('stripe-mock')

source=(
  "stripe-mock_${pkgver}_linux_amd64.tar.gz::https://github.com/stripe/stripe-mock/releases/download/v${pkgver}/stripe-mock_${pkgver}_linux_amd64.tar.gz"
)
sha256sums=('b6448357c12ecce077a5ea80e5aa7b2b906c58f3e70bca8b661f55a7a54ef7e2')

package() {
  cd "$srcdir"

  install -Dm755 "stripe-mock" "$pkgdir/usr/bin/stripe-mock"
  install -Dm644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm644 "README.md" "$pkgdir/usr/share/doc/$pkgname/README.md"
}
