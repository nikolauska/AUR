# Maintainer: Niko Lehtovirta <niko@lehtovirta.dev>

pkgname=agnix-bin
pkgver=0.40.0
pkgrel=1
pkgdesc="Linter for AI agent configurations"
arch=('x86_64' 'aarch64')
options=('!debug' '!strip')
url="https://www.npmjs.com/package/agnix"
license=('MIT' 'Apache-2.0')
depends=('glibc' 'gcc-libs')
provides=('agnix')
conflicts=('agnix')

source=(
  "LICENSE-MIT::https://raw.githubusercontent.com/agent-sh/agnix/v${pkgver}/LICENSE-MIT"
  "LICENSE-APACHE::https://raw.githubusercontent.com/agent-sh/agnix/v${pkgver}/LICENSE-APACHE"
)
source_x86_64=(
  "agnix-${pkgver}-x86_64.tar.gz::https://github.com/agent-sh/agnix/releases/download/v${pkgver}/agnix-x86_64-unknown-linux-gnu.tar.gz"
)
source_aarch64=(
  "agnix-${pkgver}-aarch64.tar.gz::https://github.com/agent-sh/agnix/releases/download/v${pkgver}/agnix-aarch64-unknown-linux-gnu.tar.gz"
)
sha256sums=('c3a85d8bd6d5967088912c35ea7df7b11d408466a094e3057a65a78b889888b2'
            'bbfece0aadd9434b813a4e2955084a75fc4b1761a4cdb017323e87f6dd156a88')
sha256sums_x86_64=('9452e72f477c5f47917dd523c9510d4a013a8ee33afaa3e8d5d94fa3d1da7690')
sha256sums_aarch64=('b1809554d659d04e5f8331e23dca2e9a031724d531716300e3eb80589daa83fd')

package() {
  install -dm755 "${pkgdir}/usr/bin"
  tar -xOzf "${srcdir}/agnix-${pkgver}-${CARCH}.tar.gz" agnix \
    > "${pkgdir}/usr/bin/agnix"
  chmod 755 "${pkgdir}/usr/bin/agnix"
  install -Dm644 "${srcdir}/LICENSE-MIT" \
    "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-MIT"
  install -Dm644 "${srcdir}/LICENSE-APACHE" \
    "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-APACHE"
}
