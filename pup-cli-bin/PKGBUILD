pkgname=pup-cli-bin
pkgver=1.6.6
pkgrel=1
pkgdesc="CLI companion for interacting with Datadog products"
arch=('x86_64' 'aarch64')
options=('!debug')
url="https://github.com/DataDog/pup"
license=('Apache-2.0')
provides=('pup-cli')
conflicts=('pup-cli' 'pup')

source_x86_64=("pup-${pkgver}-x86_64.tar.gz::https://github.com/DataDog/pup/releases/download/v${pkgver}/pup_${pkgver}_Linux_x86_64.tar.gz")
source_aarch64=("pup-${pkgver}-aarch64.tar.gz::https://github.com/DataDog/pup/releases/download/v${pkgver}/pup_${pkgver}_Linux_arm64.tar.gz")
sha256sums_x86_64=('a4d613e29093e31ce1ff80cac829e690870e2de1aeb0a3bf3a6ca1e3ff4472eb')
sha256sums_aarch64=('358e22a32633388293b008946b01c0bfb0f6d1d3c27418df932245ae785bbaf9')

package() {
  install -Dm755 "$srcdir/pup" "$pkgdir/usr/bin/pup"
  install -Dm644 "$srcdir/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm644 "$srcdir/LICENSE-3rdparty.csv" "$pkgdir/usr/share/licenses/$pkgname/LICENSE-3rdparty.csv"
}
