# Maintainer: Niko Lehtovirta <niko@lehtovirta.dev>

pkgname=skills-bin
_pkgname=skills
pkgver=1.5.19
pkgrel=1
pkgdesc="CLI for the open agent skills ecosystem"
arch=('any')
url="https://github.com/vercel-labs/skills"
license=('MIT')
depends=('git' 'nodejs>=18')
makedepends=('npm')
provides=('skills')
conflicts=('skills')

source=("https://registry.npmjs.org/${_pkgname}/-/${_pkgname}-${pkgver}.tgz")
noextract=("${_pkgname}-${pkgver}.tgz")
sha512sums=('491d3971b364f91d7b19f68216ff781e5ab91170e95026c6d192fdf84622e54107cd43c0025fa496cd8bc424feebbc005a53806a7530cd97a421542fa429a9e7')

package() {
  npm install -s -g \
    --cache "${srcdir}/npm-cache" \
    --prefix "${pkgdir}/usr" \
    "${srcdir}/${_pkgname}-${pkgver}.tgz"

  install -Dm644 \
    "${pkgdir}/usr/lib/node_modules/${_pkgname}/ThirdPartyNoticeText.txt" \
    "${pkgdir}/usr/share/licenses/${pkgname}/ThirdPartyNoticeText.txt"
}
