pkgname=codebase-memory-mcp-axi-bin
_pkgname=cbm-axi
pkgver=0.4.0
pkgrel=1
pkgdesc="Agent-oriented codebase-memory-mcp CLI with compact TOON output"
arch=('x86_64' 'aarch64')
options=('!debug' '!strip')
url="https://www.npmjs.com/package/@nikolauska/cbm-axi"
license=('MIT')
depends=('codebase-memory-mcp' 'nodejs>=18')
makedepends=('npm')
provides=('codebase-memory-mcp-axi')
conflicts=('codebase-memory-mcp-axi')

source=("${_pkgname}-${pkgver}.tgz::https://registry.npmjs.org/@nikolauska/${_pkgname}/-/${_pkgname}-${pkgver}.tgz")
noextract=("${_pkgname}-${pkgver}.tgz")
sha512sums=('8849e575b34975e34d52067f707e91ed55832af49d7f4eee1f7de449ffcea5f3e6139bdc6ad057dd58d1ca683de01fd182961f45c9c3e1c2a902f627dc5efa39')

package() {
  npm install -s -g \
    --cache "${srcdir}/npm-cache" \
    --prefix "${pkgdir}/usr" \
    "${srcdir}/${_pkgname}-${pkgver}.tgz"

  install -Dm644 \
    "${pkgdir}/usr/lib/node_modules/@nikolauska/${_pkgname}/LICENSE" \
    "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
