pkgname=tidewave-cli-bin
pkgver=0.4.5
pkgrel=1
pkgdesc="Tidewave CLI"
arch=('x86_64')
options=('!debug')
url="https://github.com/tidewave-ai/tidewave_app"
license=('Apache-2.0')
depends=('glibc' 'libgcc_s.so')
provides=('tidewave-cli')
conflicts=('tidewave-cli')

source=(
  "tidewave-cli-${CARCH}-${pkgver}-${pkgrel}-unknown-linux-gnu::https://github.com/tidewave-ai/tidewave_app/releases/download/v${pkgver}/tidewave-cli-${CARCH}-unknown-linux-gnu"
  "LICENSE::https://raw.githubusercontent.com/tidewave-ai/tidewave_app/v${pkgver}/LICENSE"
)
sha256sums=('7f2a229a583531a9a9b282d7d0588341965550a664c7d77561522db858b8a0d0'
            '59899c6091b540582ed617e8eeaac4919dc985ccfc35459ee9752b699be5205b')

package() {
  cd "$srcdir"

  install -Dm755 "tidewave-cli-${CARCH}-${pkgver}-${pkgrel}-unknown-linux-gnu" "$pkgdir/usr/bin/tidewave"
  install -Dm644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
