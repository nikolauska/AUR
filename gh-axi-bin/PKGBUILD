# Maintainer: Niko Lehtovirta <niko@lehtovirta.dev>

pkgname=gh-axi-bin
_pkgname=gh-axi
pkgver=0.1.26
pkgrel=1
pkgdesc="AXI-compliant GitHub CLI wrapper"
arch=('any')
url="https://github.com/kunchenguid/gh-axi"
license=('MIT')
depends=('github-cli' 'nodejs')
makedepends=('npm')
provides=('gh-axi')
conflicts=('gh-axi')

source=("https://registry.npmjs.org/${_pkgname}/-/${_pkgname}-${pkgver}.tgz")
noextract=("${_pkgname}-${pkgver}.tgz")
sha512sums=('f4ec81be656b88cba12930b350fa1dbcadf793554995d0a97b32fec76813a4bddd0b7694bd048f577a8996eb75d9a403107323a0cb8ebca8bada9da1420b00b5')

package() {
  npm install -s -g \
    --cache "${srcdir}/npm-cache" \
    --prefix "${pkgdir}/usr" \
    "${srcdir}/${_pkgname}-${pkgver}.tgz"

  install -Dm644 \
    "${pkgdir}/usr/lib/node_modules/${_pkgname}/LICENSE" \
    "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
